    "paths": {
  
      "/inserir": {
        "post": {
          "tags": ["Usuários"],
          "summary": "Criar usuário",
          "requestBody": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UsuarioInput" }
              }
            }
          },
          "responses": { "200": { "description": "OK" } }
        }
      },
  
      "/mostrar": {
        "get": {
          "tags": ["Usuários"],
          "summary": "Listar usuários",
          "responses": {
            "200": {
              "description": "Lista",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/Usuario" }
                  }
                }
              }
            }
          }
        }
      },
  
      "/atualizar": {
        "put": {
          "tags": ["Usuários"],
          "summary": "Atualizar usuário",
