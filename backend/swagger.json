        "nome": { "type": "string" },
        "especie": { "type": "string" },
        "raca": { "type": "string" },
        "porte": { "type": "string" },
        "idade": { "type": "string" },
        "sexo": { "type": "string" },
        "descricao": { "type": "string" },
        "status": { "type": "string" },
        "imagem": { "type": "string" },
        "ong": { "type": "string" },
