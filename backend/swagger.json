{
    "openapi": "3.0.0",
    "info": {
      "title": "API Backend",
      "version": "1.0.0",
      "description": "Sistema completo de adoção, ONGs, eventos, necessidades e doações."
    },
  
    "servers": [
      {
        "url": "http://localhost:3000"
      }
    ],
  
    "tags": [
      { "name": "Usuários" },
      { "name": "Autenticação" },
      { "name": "Animais" },
      { "name": "ONGs" },
      { "name": "Dicas" },
      { "name": "Doações" },
      { "name": "Necessidades" },
      { "name": "Eventos" }
