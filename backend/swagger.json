      "/deletar": {
        "delete": {
          "tags": ["Usuários"],
          "summary": "Deletar usuário",
          "requestBody": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id_usuario": { "type": "integer" }
