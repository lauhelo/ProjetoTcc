    "components": {
      "schemas": {
  
        "Login": {
          "type": "object",
          "properties": {
            "email": { "type": "string" },
            "senha": { "type": "string" }
          }
        },
  
        "Usuario": {
          "type": "object",
          "properties": {
            "id_usuario": { "type": "integer" },
            "nome": { "type": "string" },
            "email": { "type": "string" },
            "senha": { "type": "string" }
          }
        },
  
        "UsuarioInput": {
          "type": "object",
          "properties": {
            "nome": { "type": "string" },
            "email": { "type": "string" },
            "senha": { "type": "string" }
          }
        },
  
        "Animal": {
          "type": "object",
          "properties": {
            "id_animal": { "type": "integer" },
            "nome": { "type": "string" },
            "especie": { "type": "string" }
          }
        },
  
        "AnimalInput": {
          "type": "object",
          "properties": {
            "nome": { "type": "string" },
            "especie": { "type": "string" }
          }
        },
  
        "Ong": {
          "type": "object",
          "properties": {
            "id_ong": { "type": "integer" },
            "nome": { "type": "string" }
          }
        },
  
        "OngInput": {
          "type": "object",
          "properties": {
            "nome": { "type": "string" }
          }
        },
  
        "Dica": {
          "type": "object",
          "properties": {
            "id_dica": { "type": "integer" },
            "titulo": { "type": "string" }
          }
        },
  
        "DicaInput": {
          "type": "object",
          "properties": {
            "titulo": { "type": "string" }
          }
        },
  
        "Doacao": {
          "type": "object",
          "properties": {
            "id_doacao": { "type": "integer" },
            "descricao": { "type": "string" }
          }
        },
  
        "DoacaoInput": {
          "type": "object",
          "properties": {
