{
    "openapi": "3.0.0",
    "info": {
      "title": "API de Proteção Animal, ONGs e Eventos",
      "description": "Documentação completa e detalhada de todas as rotas da API para gestão de utilizadores, animais, ONGs, dicas, necessidades, eventos e histórias de sucesso (homenagens).",
      "version": "1.0.0"
    },
    "servers": [
      {
        "url": "http://localhost:3000",
        "description": "Servidor Local"
      }
    ],
    "components": {
      "securitySchemes": {
        "BearerAuth": {
          "type": "http",
          "scheme": "bearer",
          "bearerFormat": "JWT",
          "description": "Insere o token JWT gerado no login ou registo. Formato: `Bearer <token>`"
        }
      }
    },
    "paths": {
      "/inserir": {
        "post": {
          "summary": "Registar um novo utilizador ou ONG",
          "tags": ["Utilizadores / Autenticação"],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["nome", "email", "senha"],
                  "properties": {
                    "nome": { "type": "string", "example": "João Silva" },
                    "email": { "type": "string", "format": "email", "example": "joao@email.com" },
                    "cep": { "type": "string", "example": "12345-678", "nullable": true },
                    "cpf": { "type": "string", "example": "123.456.789-00", "nullable": true },
                    "telefone": { "type": "string", "example": "(11) 99999-9999", "nullable": true },
                    "data_nascimento": { "type": "string", "format": "date", "example": "1995-05-15", "nullable": true },
                    "senha": { "type": "string", "example": "senhaSegura123" },
                    "palavra_chave": { "type": "string", "example": "gato", "nullable": true },
                    "tipo": { "type": "string", "default": "usuario", "example": "ong" }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Utilizador cadastrado com sucesso!" },
            "400": { "description": "Dados obrigatórios em falta ou e-mail já registado." },
            "500": { "description": "Erro interno no servidor ao processar o registo." }
          }
        }
      },
      "/login": {
        "post": {
          "summary": "Autenticação Unificada (Login)",
          "tags": ["Utilizadores / Autenticação"],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["email", "senha"],
                  "properties": {
                    "email": { "type": "string", "format": "email", "example": "joao@email.com" },
                    "senha": { "type": "string", "example": "senhaSegura123" }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Autenticação bem-sucedida. Retorna o Token JWT.",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "token": { "type": "string" }
                    }
                  }
                }
              }
            },
            "401": { "description": "E-mail ou palavra-passe incorretos." },
            "500": { "description": "Erro interno no servidor ao realizar o login." }
          }
        }
      },
      "/mostrar": {
        "get": {
          "summary": "Listar todos os utilizadores (Apenas Autenticados)",
          "tags": ["Utilizadores / Autenticação"],
          "security": [{ "BearerAuth": [] }],
          "responses": {
            "200": { "description": "Lista de utilizadores registados devolvida com sucesso." },
            "401": { "description": "Token não enviado, inválido ou expirado." },
            "500": { "description": "Erro interno ao listar utilizadores." }
          }
        }
      },
      "/atualizar": {
        "put": {
          "summary": "Atualizar o perfil do utilizador autenticado",
          "tags": ["Utilizadores / Autenticação"],
          "security": [{ "BearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["id_usuario", "nome", "email"],
                  "properties": {
                    "id_usuario": { "type": "integer", "example": 1, "description": "ID do utilizador a atualizar (deve corresponder ao utilizador logado)" },
                    "nome": { "type": "string", "example": "João Silva Atualizado" },
                    "email": { "type": "string", "format": "email", "example": "joao.novo@email.com" },
                    "cep": { "type": "string", "example": "12345-678" },
                    "cpf": { "type": "string", "example": "123.456.789-00" },
                    "telefone": { "type": "string", "example": "(11) 98888-8888" },
                    "data_nascimento": { "type": "string", "example": "1995-05-15" },
                    "senha": { "type": "string", "description": "Opcional. Se enviado, atualiza a password do utilizador." },
                    "palavra_chave": { "type": "string", "example": "cachorro" }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Perfil atualizado com sucesso!" },
            "401": { "description": "Não autorizado ou token inválido." },
            "403": { "description": "Ação não permitida. Não pode atualizar o perfil de outro utilizador." },
            "500": { "description": "Erro interno ao atualizar utilizador." }
          }
        }
      },
      "/deletar": {
        "delete": {
          "summary": "Eliminar a própria conta de utilizador",
          "tags": ["Utilizadores / Autenticação"],
          "security": [{ "BearerAuth": [] }],
          "responses": {
            "200": { "description": "Conta eliminada com sucesso!" },
            "401": { "description": "Não autorizado." },
            "404": { "description": "Utilizador não encontrado no sistema." },
            "500": { "description": "Erro ao eliminar conta (pode conter restrições de chave estrangeira)." }
          }
        }
      },
      "/recuperar-senha": {
        "put": {
          "summary": "Recuperar ou alterar password utilizando a palavra-chave",
          "tags": ["Utilizadores / Autenticação"],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["email", "senha", "confirmar_senha", "palavra_chave"],
                  "properties": {
                    "email": { "type": "string", "format": "email", "example": "joao@email.com" },
                    "senha": { "type": "string", "example": "novaSenha123" },
                    "confirmar_senha": { "type": "string", "example": "novaSenha123" },
                    "palavra_chave": { "type": "string", "example": "gato" }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Senha atualizada com sucesso!" },
            "400": { "description": "Campos obrigatórios em falta ou as passwords introduzidas não coincidem." },
            "401": { "description": "E-mail ou Palavra-Chave incorretos." },
            "500": { "description": "Erro ao redefinir a palavra-passe." }
          }
        }
      },
      "/mostrarAnimal": {
        "get": {
          "summary": "Listar animais com filtros básicos (Público)",
          "tags": ["Animais"],
          "parameters": [
            { "name": "especie", "in": "query", "required": false, "schema": { "type": "string" }, "example": "Cachorro" },
            { "name": "sexo", "in": "query", "required": false, "schema": { "type": "string" }, "example": "Macho" },
            { "name": "porte", "in": "query", "required": false, "schema": { "type": "string" }, "example": "Médio" }
          ],
          "responses": {
            "200": { "description": "Lista de animais filtrados obtida com sucesso." }
          }
        }
      },
      "/animais": {
        "get": {
          "summary": "Listar animais disponíveis ou detalhes específicos por ID (Protegido)",
          "tags": ["Animais"],
          "security": [{ "BearerAuth": [] }],
          "parameters": [
            { "name": "id", "in": "query", "description": "Insere o ID para obter detalhes de um único animal", "required": false, "schema": { "type": "integer" } },
            { "name": "especie", "in": "query", "required": false, "schema": { "type": "string" } },
            { "name": "sexo", "in": "query", "required": false, "schema": { "type": "string" } },
            { "name": "porte", "in": "query", "required": false, "schema": { "type": "string" } }
          ],
          "responses": {
            "200": { "description": "Resultados obtidos com sucesso." },
            "401": { "description": "Não autorizado." },
            "404": { "description": "Animal com o ID especificado não foi encontrado." }
          }
        }
      },
      "/inserirAnimal": {
        "post": {
          "summary": "Registar um novo animal",
          "tags": ["Animais"],
          "security": [{ "BearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["nome"],
                  "properties": {
                    "id_ong": { "type": "integer", "description": "Opcional. Se não enviado, é associado automaticamente através do token." },
                    "nome": { "type": "string", "example": "Rex" },
                    "especie": { "type": "string", "example": "Cachorro" },
                    "raca": { "type": "string", "example": "Labrador" },
                    "porte": { "type": "string", "example": "Grande" },
                    "idade": { "type": "string", "example": "2 anos" },
                    "sexo": { "type": "string", "example": "Macho" },
                    "descricao": { "type": "string", "example": "Muito dócil e brincalhão." },
                    "status": { "type": "string", "example": "Disponível" },
                    "imagem": { "type": "string", "description": "String Base64 ou URL da imagem do animal" },
                    "ong": { "type": "string", "example": "ONG Patas Felizes" },
                    "cidade": { "type": "string", "example": "São Paulo" },
                    "estado": { "type": "string", "example": "SP" }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Animal cadastrado com sucesso!" },
            "400": { "description": "O nome do animal está em falta ou a ONG não pôde ser identificada." },
            "401": { "description": "Não autorizado." }
          }
        }
      },
      "/atualizarAnimal/{id}": {
        "put": {
          "summary": "Atualizar os dados de um animal existente",
          "tags": ["Animais"],
          "security": [{ "BearerAuth": [] }],
          "parameters": [
            { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "ID do animal a ser atualizado" }
          ],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "nome": { "type": "string" },
                    "especie": { "type": "string" },
                    "raca": { "type": "string" },
                    "porte": { "type": "string" },
                    "idade": { "type": "string" },
                    "sexo": { "type": "string" },
                    "descricao": { "type": "string" },
                    "status": { "type": "string" },
                    "imagem": { "type": "string" }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Animal atualizado com sucesso!" },
            "401": { "description": "Não autorizado." },
            "404": { "description": "Animal não encontrado ou não pertence à sua ONG." }
          }
        }
      },
      "/excluirAnimal/{id}": {
        "delete": {
          "summary": "Remover um animal do sistema",
          "tags": ["Animais"],
          "security": [{ "BearerAuth": [] }],
          "parameters": [
            { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "ID do animal a eliminar" }
          ],
          "responses": {
            "200": { "description": "Animal excluído com sucesso!" },
            "401": { "description": "Não autorizado." },
            "404": { "description": "Animal não encontrado na base de dados." }
          }
        }
      },
      "/minhas-ongs": {
        "get": {
          "summary": "Listar as ONGs vinculadas ao utilizador autenticado",
          "tags": ["ONGs"],
          "security": [{ "BearerAuth": [] }],
          "responses": {
            "200": { "description": "Lista de ONGs do utilizador devolvida com sucesso." },
            "401": { "description": "Não autorizado." }
          }
        }
      },
      "/mostrarOng/{id}": {
        "get": {
          "summary": "Obter detalhes de uma ONG específica por ID",
          "tags": ["ONGs"],
          "security": [{ "BearerAuth": [] }],
          "parameters": [
            { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
          ],
          "responses": {
            "200": { "description": "Dados da ONG obtidos com sucesso." },
            "401": { "description": "Não autorizado." },
            "404": { "description": "ONG não encontrada." }
          }
        }
      },
      "/inserirOng": {
        "post": {
          "summary": "Criar e vincular uma nova ONG",
          "tags": ["ONGs"],
          "security": [{ "BearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["nome", "email", "cnpj"],
                  "properties": {
                    "nome": { "type": "string", "example": "Associação Protetora Dos Animais" },
                    "email": { "type": "string", "format": "email", "example": "contacto@ong.com" },
                    "telefone": { "type": "string", "example": "(11) 5555-5555" },
                    "endereco": { "type": "string", "example": "Rua das Flores, 123" },
                    "cnpj": { "type": "string", "example": "12.345.678/0001-99" },
                    "cidade": { "type": "string", "example": "Campinas" },
                    "estado": { "type": "string", "example": "SP" },
                    "pix": { "type": "string", "example": "contacto@ong.com", "nullable": true },
                    "trabalho_ofe": { "type": "string", "example": "Resgate e reabilitação de animais de rua.", "nullable": true }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "ONG registada e associada ao seu utilizador com sucesso!" },
            "401": { "description": "Não autorizado." }
          }
        }
      },
      "/atualizarOng/{id}": {
        "put": {
          "summary": "Atualizar os dados de uma ONG",
          "tags": ["ONGs"],
          "security": [{ "BearerAuth": [] }],
          "parameters": [
            { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
          ],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "nome": { "type": "string" },
                    "email": { "type": "string", "format": "email" },
                    "telefone": { "type": "string" },
                    "endereco": { "type": "string" },
                    "cidade": { "type": "string" },
                    "estado": { "type": "string" },
                    "pix": { "type": "string" },
                    "trabalho_ofe": { "type": "string" }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "ONG atualizada com sucesso!" },
            "401": { "description": "Não autorizado." },
            "404": { "description": "ONG não encontrada ou não pertence ao utilizador autenticado." }
          }
        }
      },
      "/deletarOng/{id}": {
        "delete": {
          "summary": "Remover uma ONG por ID",
          "tags": ["ONGs"],
          "security": [{ "BearerAuth": [] }],
          "parameters": [
            { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
          ],
          "responses": {
            "200": { "description": "ONG removida com sucesso do sistema." },
            "401": { "description": "Não autorizado." },
            "404": { "description": "ONG não encontrada." }
          }
        }
      },
      "/mostrarDicas": {
        "get": {
          "summary": "Listar todas as dicas publicadas (Público)",
          "tags": ["Dicas"],
          "responses": {
            "200": { "description": "Lista de dicas ordenadas das mais recentes para as mais antigas." }
          }
        }
      },
      "/inserirDica": {
        "post": {
          "summary": "Publicar uma nova dica de cuidados com animais",
          "tags": ["Dicas"],
          "security": [{ "BearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["titulo", "categoria", "qualPet", "conteudo"],
                  "properties": {
                    "titulo": { "type": "string", "example": "Como alimentar cachorros filhotes" },
                    "categoria": { "type": "string", "example": "Alimentação" },
                    "qualPet": { "type": "string", "example": "Cachorros" },
                    "conteudo": { "type": "string", "example": "Filhotes devem comer ração específica de 3 a 4 vezes ao dia..." }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Dica publicada com sucesso!" },
            "400": { "description": "Campos obrigatórios em falta no corpo da requisição." },
            "401": { "description": "Não autorizado." }
          }
        }
      },
      "/atualizarDica": {
        "put": {
          "summary": "Atualizar uma dica existente",
          "tags": ["Dicas"],
          "security": [{ "BearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["id_dica"],
                  "properties": {
                    "id_dica": { "type": "integer", "example": 1 },
                    "titulo": { "type": "string" },
                    "categoria": { "type": "string" },
                    "qualPet": { "type": "string" },
                    "conteudo": { "type": "string" }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Dica atualizada com sucesso!" },
            "401": { "description": "Não autorizado." }
          }
        }
      },
      "/deletarDica": {
        "delete": {
          "summary": "Remover uma dica do sistema",
          "tags": ["Dicas"],
          "security": [{ "BearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["id_dica"],
                  "properties": {
                    "id_dica": { "type": "integer", "example": 1 }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Dica removida com sucesso!" },
            "401": { "description": "Não autorizado." }
          }
        }
      },
      "/mostrarNecessidades": {
        "get": {
          "summary": "Listar necessidades dos animais (Público)",
          "tags": ["Necessidades dos Animais"],
          "responses": {
            "200": { "description": "Retorna a lista de necessidades cruzando com os nomes dos respetivos animais." }
          }
        }
      },
      "/inserirNecessidade": {
        "post": {
          "summary": "Registar uma nova necessidade para um animal",
          "tags": ["Necessidades dos Animais"],
          "security": [{ "BearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["id_animal", "nome"],
                  "properties": {
                    "id_animal": { "type": "integer", "example": 5 },
                    "nome": { "type": "string", "example": "Ração Especial Hipoalergénica" },
                    "categoria": { "type": "string", "example": "Alimentação" },
                    "grau_importancia": { "type": "string", "example": "Alta" },
                    "descricao": { "type": "string", "example": "O animal sofre de dermatite severa." },
                    "botao": { "type": "string", "example": "Doar Ração" }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Necessidade registada/processada com sucesso." },
            "401": { "description": "Não autorizado." }
          }
        }
      },
      "/atualizarNecessidade": {
        "put": {
          "summary": "Atualizar os dados de uma necessidade",
          "tags": ["Necessidades dos Animais"],
          "security": [{ "BearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["id_necessidade"],
                  "properties": {
                    "id_necessidade": { "type": "integer", "example": 1 },
                    "id_animal": { "type": "integer" },
                    "nome": { "type": "string" },
                    "categoria": { "type": "string" },
                    "grau_importancia": { "type": "string" },
                    "descricao": { "type": "string" },
                    "botao": { "type": "string" }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Necessidade atualizada com sucesso." },
            "401": { "description": "Não autorizado." }
          }
        }
      },
      "/deletarNecessidade": {
        "delete": {
          "summary": "Remover uma necessidade do sistema",
          "tags": ["Necessidades dos Animais"],
          "security": [{ "BearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["id_necessidade"],
                  "properties": {
                    "id_necessidade": { "type": "integer", "example": 1 }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Necessidade eliminada com sucesso!" },
            "401": { "description": "Não autorizado." }
          }
        }
      },
      "/mostrarEventos": {
        "get": {
          "summary": "Listar todos os eventos (Público)",
          "tags": ["Eventos das ONGs"],
          "responses": {
            "200": { "description": "Lista completa de eventos com os dados das respetivas ONGs organizadoras." }
          }
        }
      },
      "/eventos-proximos": {
        "get": {
          "summary": "Pesquisar eventos baseando-se na geolocalização (Fórmula de Haversine)",
          "tags": ["Eventos das ONGs"],
          "parameters": [
            { "name": "lat", "in": "query", "description": "Latitude atual do utilizador", "required": true, "schema": { "type": "number", "format": "float" }, "example": -23.55052 },
            { "name": "lng", "in": "query", "description": "Longitude atual do utilizador", "required": true, "schema": { "type": "number", "format": "float" }, "example": -46.633308 },
            { "name": "raio", "in": "query", "description": "Raio de pesquisa em quilómetros. Padrão: 50km", "required": false, "schema": { "type": "number" }, "example": 25 }
          ],
          "responses": {
            "200": { "description": "Lista de eventos ordenados por proximidade física calculada." },
            "400": { "description": "Parâmetros 'lat' ou 'lng' em falta na query string." }
          }
        }
      },
      "/inserirEvento": {
        "post": {
          "summary": "Criar um novo evento para a sua ONG",
          "tags": ["Eventos das ONGs"],
          "security": [{ "BearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["nome_evento"],
                  "properties": {
                    "nome_evento": { "type": "string", "example": "Feira de Adoção de Sábado" },
                    "hora": { "type": "string", "example": "10:00:00" },
                    "data": { "type": "string", "format": "date", "example": "2026-07-12" },
                    "endereco": { "type": "string", "example": "Praça Central, Centro" },
                    "categoria": { "type": "string", "example": "Feira de Adoção" },
                    "localizacao": { "type": "string", "example": "Parque da Cidade" },
                    "imagem": { "type": "string", "description": "URL ou Base64 do cartaz do evento", "nullable": true },
                    "latitude": { "type": "number", "format": "float", "example": -23.5505, "nullable": true },
                    "longitude": { "type": "number", "format": "float", "example": -46.6333, "nullable": true }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Evento criado com sucesso!" },
            "401": { "description": "Não autorizado." },
            "403": { "description": "Ação negada. O utilizador autenticado não tem nenhuma ONG vinculada." }
          }
        }
      },
      "/atualizarEvento": {
        "put": {
          "summary": "Atualizar os dados de um evento da sua ONG",
          "tags": ["Eventos das ONGs"],
          "security": [{ "BearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["id_evento"],
                  "properties": {
                    "id_evento": { "type": "integer", "example": 1 },
                    "nome_evento": { "type": "string" },
                    "hora": { "type": "string" },
                    "data": { "type": "string" },
                    "endereco": { "type": "string" },
                    "categoria": { "type": "string" },
                    "localizacao": { "type": "string" },
                    "imagem": { "type": "string" },
                    "latitude": { "type": "number" },
                    "longitude": { "type": "number" }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Evento modificado com sucesso!" },
            "401": { "description": "Não autorizado." },
            "403": { "description": "Ação proibida. Este evento pertence a uma ONG gerida por outro utilizador." },
            "404": { "description": "O evento solicitado não foi encontrado." }
          }
        }
      },
      "/deletarEvento": {
        "delete": {
          "summary": "Remover um evento da sua ONG",
          "tags": ["Eventos das ONGs"],
          "security": [{ "BearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["id_evento"],
                  "properties": {
                    "id_evento": { "type": "integer", "example": 1 }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Evento removido com sucesso!" },
            "401": { "description": "Não autorizado." },
            "403": { "description": "Não permitido eliminar eventos de terceiros." }
          }
        }
      },
      "/api/historias": {
        "get": {
          "summary": "Listar todas as histórias de sucesso / homenagens (Público)",
          "tags": ["Histórias de Sucesso (Homenagens)"],
          "responses": {
            "200": { "description": "Retorna a lista de histórias formatadas (com fallback de imagem padrão caso esteja vazia)." }
          }
        },
        "post": {
          "summary": "Publicar uma nova história de sucesso",
          "tags": ["Histórias de Sucesso (Homenagens)"],
          "security": [{ "BearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["titulo", "texto"],
                  "properties": {
                    "titulo": { "type": "string", "example": "A adoção do Floquinho" },
                    "texto": { "type": "string", "example": "Depois de 3 anos no abrigo, ele finalmente encontrou um lar..." },
                    "imagens": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Lista de imagens. O sistema consome o índice [0] para a foto da história.",
                      "example": ["https://exemplo.com/foto-pet.jpg"]
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "201": { "description": "História publicada e guardada com sucesso." },
            "400": { "description": "Campos obrigatórios em falta ('titulo' ou 'texto')." },
            "401": { "description": "Não autorizado." }
          }
        }
      },
      "/api/historias/{id}": {
        "put": {
          "summary": "Atualizar uma história por ID (Apenas o Criador)",
          "tags": ["Histórias de Sucesso (Homenagens)"],
          "security": [{ "BearerAuth": [] }],
          "parameters": [
            { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "ID da história a modificar" }
          ],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "titulo": { "type": "string" },
                    "texto": { "type": "string" },
                    "imagens": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "História alterada com sucesso." },
            "401": { "description": "Não autorizado." },
            "403": { "description": "Ação proibida. Não é o criador/ONG original desta história." },
            "404": { "description": "História não encontrada no sistema." }
          }
        },
        "delete": {
          "summary": "Eliminar uma história por ID (Apenas o Criador)",
          "tags": ["Histórias de Sucesso (Homenagens)"],
          "security": [{ "BearerAuth": [] }],
          "parameters": [
            { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
          ],
          "responses": {
            "200": { "description": "História eliminada com sucesso do banco de dados." },
            "401": { "description": "Não autorizado." },
            "403": { "description": "Não tem permissão para remover histórias criadas por outras contas." },
            "404": { "description": "História não encontrada." }
          }
        }
      }
    }
  }